{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/heads/dev/crates/tauri-utils/schema.json",
  "productName": "Terse",
  "version": "1.3.0",
  "identifier": "com.terse.app",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../src/helpers/terse-ax": "terse-ax",
      "../src/helpers/terse-compress.js": "terse-compress.js",
      "../src/helpers/terse-rewrite.sh": "terse-rewrite.sh",
      "../src/helpers/hooks/terse-hook-cursor.sh": "hooks/terse-hook-cursor.sh",
      "../src/helpers/hooks/terse-hook-cline.sh": "hooks/terse-hook-cline.sh",
      "../src/helpers/hooks/terse-hook-codex.sh": "hooks/terse-hook-codex.sh",
      "../src/helpers/hooks/terse-hook-copilot.sh": "hooks/terse-hook-copilot.sh",
      "../src/helpers/hooks/terse-hook-openclaw.ts": "hooks/terse-hook-openclaw.ts",
      "../src/helpers/hooks/terse-hook-windsurf.sh": "hooks/terse-hook-windsurf.sh",
      "../src/helpers/terse-optimize-tools.sh": "terse-optimize-tools.sh",
      "../src/helpers/hooks/terse-tool-optimizer-cursor.sh": "hooks/terse-tool-optimizer-cursor.sh",
      "../src/helpers/hooks/terse-tool-optimizer-codex.sh": "hooks/terse-tool-optimizer-codex.sh",
      "../src/helpers/hooks/terse-tool-optimizer-cline.sh": "hooks/terse-tool-optimizer-cline.sh",
      "../src/helpers/hooks/terse-tool-optimizer-windsurf.sh": "hooks/terse-tool-optimizer-windsurf.sh",
      "../src/helpers/hooks/terse-tool-optimizer-copilot.sh": "hooks/terse-tool-optimizer-copilot.sh"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Terse",
        "url": "index.html",
        "width": 340,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "shadow": true,
        "visible": true,
        "visibleOnAllWorkspaces": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  }
}
